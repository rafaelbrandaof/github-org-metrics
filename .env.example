# Required
GITHUB_TOKEN=ghp_your_token_here

# Optional overrides
GITHUB_ORG=augentic-tech
TARGET_REPOS=qomitto-enrollment qomitto-gateway qomitto-data-service qomitto-search-service qomitto-driver-license-service qomitto-camunda qomitto-order-service qomitto-report-service qomitto-backoffice
DASHBOARD_USER=admin
DASHBOARD_PASS=admin
FLASK_SECRET_KEY=change-me-in-production
COLLECT_MONTHS=12

# Cron schedule (default: every Monday at 06:00 UTC)
CRON_SCHEDULE=0 6 * * 1
